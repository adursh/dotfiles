#!/usr/bin/env bash

# turn on and connect paired devices

set -u

MAX_RETRIES=1
BT_INIT_WAIT=0
RETRY_DELAY=1

BLUEUTIL="/opt/homebrew/bin/blueutil"

log() {
  echo "[BT-RECONNECT] $*"
}

# sleep 6

log "Turning Bluetooth ON"
"$BLUEUTIL" --power 1

log "Waiting for Bluetooth stack..."
sleep "$BT_INIT_WAIT"

devices=$("$BLUEUTIL" --paired | sed -n 's/^address: \([^,]*\).*/\1/p')

for mac in $devices; do
  log "Attempting connection: $mac"

  attempt=1
  while [ $attempt -le $MAX_RETRIES ]; do
    if "$BLUEUTIL" --connect "$mac" 2>/dev/null; then
      log "Connect request sent: $mac"
      break
    else
      log "Attempt $attempt failed: $mac"
      attempt=$((attempt+1))
      sleep "$RETRY_DELAY"
    fi
  done

  if [ $attempt -gt $MAX_RETRIES ]; then
    log "Failed after $MAX_RETRIES attempts: $mac"
  fi

  sleep 1
done

log "Reconnect script finished"
