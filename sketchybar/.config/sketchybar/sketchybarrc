#!/bin/bash
export CONFIG_DIR="$HOME/.config/sketchybar"
export PLUGIN_DIR="$CONFIG_DIR/plugins"
export ITEM_DIR="$CONFIG_DIR/items"

source "$CONFIG_DIR/colors.sh"

sketchybar --bar \
  height=32         \
  position=top      \
  color=$BAR_COLOR  \
  border_width=0    \
  border_color=$SURFACE1 \
  padding_left=12   \
  padding_right=12  \
  shadow=off        \
  corner_radius=0   \
  notch_width=0     \
  sticky=on         \
  display=main

sketchybar --default \
  icon.drawing=off                          \
  label.font="SF Pro Text:Regular:12.0"     \
  label.color=$SUBTEXT0                     \
  label.padding_left=7                      \
  label.padding_right=7                     \
  padding_left=1                            \
  padding_right=1                           \
  background.height=20                      \
  background.corner_radius=7               \
  background.color=$SURFACE0               \
  background.border_width=0                \
  background.border_color=$SURFACE1        \
  background.drawing=off

source "$ITEM_DIR/spaces.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/network.sh"

sketchybar --update

# force overrides after default
sketchybar --set front_app \
  label.font="SF Pro Text:Semibold:14.0" \
  background.drawing=off

sketchybar --set network_speed \
  label.font="SF Pro Text:Regular Italic:12.0" \
  label.color=0xff6c6c8a \
  background.drawing=off

CURRENT=$(aerospace list-workspaces --focused 2>/dev/null)
[ -n "$CURRENT" ] && sketchybar --trigger aerospace_workspace_change \
  FOCUSED_WORKSPACE="$CURRENT" PREV_WORKSPACE=""
