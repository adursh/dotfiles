# catppuccin-mocha
theme = catppuccin mocha

# font
font-family = jetbrainsmono nerd font
font-size = 16
bold-is-bright = false

# focus
focus-follows-mouse = true

# window
window-padding-x = 5,5
window-padding-y = 1,1
window-padding-balance = true

# background
background-opacity = 0.85
background-blur = 30

# windows
keybind = cmd+t=text:\x00c
keybind = cmd+shift+]=text:\x00n
keybind = cmd+shift+[=text:\x00p

# panes
keybind = cmd+w=text:\x00x

# sessions
keybind = cmd+f=text:\x00\x54
keybind = cmd+q=text:\x00q

# reload
keybind = cmd+r=text:\x00r
